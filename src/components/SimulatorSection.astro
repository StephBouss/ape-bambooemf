---
import { Icon } from 'astro-icon/components';
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import { operation, web3FormsAccessKey } from '../data/operation';
import { countries } from '../data/countries';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
const locale = lang === 'fr' ? 'fr-FR' : 'en-US';
const sortedCountries = [...countries].sort((a, b) => a[lang].localeCompare(b[lang], locale));
// Espace insécable normale (U+00A0) en fr — Intl.NumberFormat('fr-FR') utilise par défaut
// l'espace fine U+202F, quasi invisible dans beaucoup de polices. Même logique dans simulator.ts.
const initialAmountDisplay = (lang === 'fr' ? '1 000 000' : '1,000,000');
---
<section id="simulateur" class="py-24 bg-white border-y border-filet">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl mb-12 reveal-group">
      <div class="eyebrow reveal-item mb-3">{t.simulator.eyebrow}</div>
      <h2 class="reveal-item font-display font-bold text-3xl md:text-4xl text-charbon">{t.simulator.title}</h2>
      <p class="reveal-item text-muted mt-3">{t.simulator.lead}</p>
    </div>

    <div class="grid lg:grid-cols-[0.9fr_1.1fr] gap-6 reveal-group">
      <div class="reveal-item bg-menthe-fond border border-filet rounded-card p-6 h-fit">
        <div class="mb-5">
          <label for="sim-residence" class="block text-xs font-semibold text-navy mb-2">{t.simulator.residenceLabel}</label>
          <select id="sim-residence" class="w-full bg-white border border-filet rounded-lg px-3.5 py-2.5 text-sm font-medium">
            <option value="hors-cemac">{t.simulator.residenceHorsCemac}</option>
            <option value="cemac" selected>{t.simulator.residenceCemac}</option>
          </select>
          <p id="sim-residence-note" class="hidden text-xs text-muted mt-2">{t.simulator.residenceNote}</p>
        </div>

        <div>
          <label for="sim-amount" class="block text-xs font-semibold text-navy mb-2">{t.simulator.amountLabel}</label>
          <input
            id="sim-amount"
            type="text"
            inputmode="numeric"
            autocomplete="off"
            value={initialAmountDisplay}
            class="w-full bg-white border border-filet rounded-lg px-3.5 py-2.5 text-sm font-semibold tabular"
          />
          <p class="text-[11px] text-muted mt-2">{t.simulator.amountHint}</p>
          <p id="sim-amount-warning" class="hidden text-xs font-semibold text-vert-foret mt-2"></p>
        </div>
      </div>

      <div class="reveal-item bg-white border border-filet rounded-card p-6 shadow-soft">
        <h3 class="eyebrow mb-4">{t.simulator.resultsTitle}</h3>
        <dl class="grid sm:grid-cols-2 gap-x-6 gap-y-4 text-sm">
          <div>
            <dt class="text-xs text-muted">{t.simulator.resultNominal}</dt>
            <dd class="font-semibold mt-0.5 tabular" data-sim="nominal">—</dd>
          </div>
          <div>
            <dt class="text-xs text-muted">{t.simulator.resultCount}</dt>
            <dd class="font-semibold mt-0.5 tabular" data-sim="count">—</dd>
          </div>
          <div>
            <dt class="text-xs text-muted">{t.simulator.resultGrossRate}</dt>
            <dd class="font-semibold mt-0.5 tabular" data-sim="grossRate">—</dd>
          </div>
          <div>
            <dt class="text-xs text-muted">{t.simulator.resultTax}</dt>
            <dd class="font-semibold mt-0.5 tabular" data-sim="tax">—</dd>
          </div>
          <div class="sm:col-span-2">
            <dt class="text-xs text-muted">{t.simulator.resultNetRate}</dt>
            <dd class="font-semibold mt-0.5 tabular" data-sim="netRate">—</dd>
          </div>
          <div class="sm:col-span-2 pt-3 border-t border-filet">
            <dt class="text-xs text-muted">{t.simulator.resultTotalInterest}</dt>
            <dd class="font-display font-bold text-lg text-vert-foret mt-0.5 tabular" data-sim="totalInterest">—</dd>
          </div>
          <div class="sm:col-span-2">
            <dt class="text-xs text-muted">{t.simulator.resultMaturityCapital}</dt>
            <dd class="font-display font-bold text-xl text-navy mt-0.5 tabular" data-sim="maturityCapital">—</dd>
          </div>
        </dl>

        <button
          type="button"
          id="sim-cta"
          class="mt-6 w-full inline-flex items-center justify-center gap-2 bg-vert-marque text-white font-semibold text-sm rounded-full px-6 py-3.5 shadow-soft hover:bg-vert-foret transition-colors group"
        >
          <Icon name="tabler:mail" class="w-4 h-4" />
          {t.simulator.ctaButton}
          <Icon name="tabler:arrow-right" class="w-4 h-4 transition-transform group-hover:translate-x-1" />
        </button>
        <p class="text-[11px] text-muted text-center mt-2.5">{t.simulator.ctaNote}</p>
      </div>
    </div>

    <div class="mt-10 reveal-item">
      <h3 class="font-display font-semibold text-sm text-charbon mb-4">{t.simulator.scheduleTitle}</h3>
      <div class="sim-table overflow-x-auto rounded-card border border-filet shadow-soft">
        <table class="w-full text-sm min-w-[720px] border-collapse">
          <thead>
            <tr class="bg-charbon text-white text-xs uppercase tracking-wide">
              <th class="text-left font-semibold px-4 py-3">{t.simulator.colDate}</th>
              <th class="text-right font-semibold px-4 py-3">{t.simulator.colStart}</th>
              <th class="text-right font-semibold px-4 py-3">{t.simulator.colInterest}</th>
              <th class="text-right font-semibold px-4 py-3">{t.simulator.colRepaid}</th>
              <th class="text-right font-semibold px-4 py-3">{t.simulator.colTotal}</th>
              <th class="text-right font-semibold px-4 py-3">{t.simulator.colEnd}</th>
            </tr>
          </thead>
          <tbody id="sim-schedule-body"></tbody>
          <tfoot>
            <tr class="bg-menthe-fond font-bold border-t-2 border-filet">
              <td class="px-4 py-3">{t.simulator.rowTotal}</td>
              <td class="px-4 py-3 text-right">—</td>
              <td class="px-4 py-3 text-right tabular" data-sim="totalInterestRow">—</td>
              <td class="px-4 py-3 text-right tabular" data-sim="totalRepaidRow">—</td>
              <td class="px-4 py-3 text-right tabular" data-sim="totalReceivedRow">—</td>
              <td class="px-4 py-3 text-right">—</td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <p class="reveal-item text-xs text-muted/80 italic border-t border-filet mt-8 pt-6">{t.simulator.disclaimer}</p>
  </div>

  <div
    id="sim-modal-overlay"
    class="hidden fixed inset-0 z-50 items-center justify-center bg-charbon/60 backdrop-blur-sm px-4"
  >
    <div class="bg-white rounded-card shadow-soft w-full max-w-md p-6 md:p-7">
      <h3 class="font-display font-bold text-xl text-charbon">{t.simulator.modalTitle}</h3>
      <p class="text-sm text-muted mt-2 mb-5">{t.simulator.modalLead}</p>

      <form id="sim-modal-form" class="space-y-4">
        <div class="grid sm:grid-cols-2 gap-4">
          <div>
            <label for="sim-modal-nom" class="block text-xs font-semibold text-navy mb-1.5">{t.simulator.modalFieldNom}</label>
            <input id="sim-modal-nom" type="text" required autocomplete="family-name" class="w-full bg-menthe-fond border border-filet rounded-lg px-3.5 py-2.5 text-sm" />
          </div>
          <div>
            <label for="sim-modal-prenom" class="block text-xs font-semibold text-navy mb-1.5">{t.simulator.modalFieldPrenom}</label>
            <input id="sim-modal-prenom" type="text" required autocomplete="given-name" class="w-full bg-menthe-fond border border-filet rounded-lg px-3.5 py-2.5 text-sm" />
          </div>
        </div>

        <div class="relative">
          <label id="sim-modal-pays-label" class="block text-xs font-semibold text-navy mb-1.5">{t.simulator.modalFieldPays}</label>
          <button
            type="button"
            id="sim-modal-pays-trigger"
            aria-haspopup="listbox"
            aria-expanded="false"
            class="w-full flex items-center gap-2 bg-menthe-fond border border-filet rounded-lg px-3.5 py-2.5 text-sm text-left"
          >
            <span id="sim-modal-pays-flag" class="w-5 h-5 rounded-full overflow-hidden shrink-0 [&>svg]:w-full [&>svg]:h-full"></span>
            <span id="sim-modal-pays-current" class="flex-1 text-muted truncate">{t.simulator.modalPaysPlaceholder}</span>
            <Icon name="tabler:chevron-down" class="w-4 h-4 text-muted shrink-0" />
          </button>

          <div
            id="sim-modal-pays-panel"
            class="hidden absolute z-10 top-full left-0 mt-1.5 w-full bg-white border border-filet rounded-lg shadow-soft flex flex-col overflow-hidden"
          >
            <input
              type="text"
              id="sim-modal-pays-filter"
              placeholder={t.simulator.modalPaysSearchPlaceholder}
              class="border-b border-filet px-3.5 py-2.5 text-sm outline-none"
            />
            <div id="sim-modal-pays-list" class="max-h-56 overflow-y-auto">
              {sortedCountries.map((c) => (
                <button
                  type="button"
                  class="sim-country-option w-full flex items-center gap-2.5 px-3.5 py-2 text-sm text-left hover:bg-menthe-fond transition-colors"
                  data-code={c.code}
                  data-name={c[lang]}
                >
                  <span class="w-5 h-5 rounded-full overflow-hidden shrink-0 [&>svg]:w-full [&>svg]:h-full">
                    <Icon name={`circle-flags:${c.code}`} />
                  </span>
                  <span class="sim-country-name truncate">{c[lang]}</span>
                </button>
              ))}
            </div>
          </div>

          <p id="sim-modal-pays-error" class="hidden text-xs font-semibold text-red-600 mt-1.5">{t.simulator.modalPaysRequired}</p>
        </div>

        <div>
          <label for="sim-modal-phone" class="block text-xs font-semibold text-navy mb-1.5">{t.simulator.modalFieldPhone}</label>
          <input id="sim-modal-phone" type="tel" required autocomplete="tel" class="w-full bg-menthe-fond border border-filet rounded-lg px-3.5 py-2.5 text-sm" />
        </div>

        <div>
          <label for="sim-modal-email" class="block text-xs font-semibold text-navy mb-1.5">{t.simulator.modalFieldEmail}</label>
          <input id="sim-modal-email" type="email" required autocomplete="email" class="w-full bg-menthe-fond border border-filet rounded-lg px-3.5 py-2.5 text-sm" />
        </div>

        <div>
          <label for="sim-modal-amount" class="block text-xs font-semibold text-navy mb-1.5">{t.simulator.modalFieldAmount}</label>
          <input id="sim-modal-amount" type="text" inputmode="numeric" autocomplete="off" required class="w-full bg-menthe-fond border border-filet rounded-lg px-3.5 py-2.5 text-sm font-semibold tabular" />
        </div>

        <div class="flex gap-3 pt-2">
          <button type="button" id="sim-modal-cancel" class="flex-1 inline-flex items-center justify-center border border-filet text-charbon font-semibold text-sm rounded-full px-6 py-3 hover:border-charbon/40 transition-colors">
            {t.simulator.modalCancel}
          </button>
          <button type="submit" class="flex-1 inline-flex items-center justify-center bg-vert-marque text-white font-semibold text-sm rounded-full px-6 py-3 shadow-soft hover:bg-vert-foret transition-colors">
            {t.simulator.modalConfirm}
          </button>
        </div>
      </form>
    </div>
  </div>

  <div
    id="sim-feedback-overlay"
    class="hidden fixed inset-0 z-[60] items-center justify-center bg-charbon/60 backdrop-blur-sm px-4"
  >
    <div class="bg-white rounded-card shadow-soft w-full max-w-sm p-7 text-center">
      <div id="sim-feedback-icon-success" class="hidden mx-auto w-14 h-14 rounded-full bg-vert-marque/15 text-vert-foret items-center justify-center mb-4">
        <Icon name="tabler:circle-check-filled" class="w-9 h-9" />
      </div>
      <div id="sim-feedback-icon-error" class="hidden mx-auto w-14 h-14 rounded-full bg-red-100 text-red-600 items-center justify-center mb-4">
        <Icon name="tabler:circle-x-filled" class="w-9 h-9" />
      </div>
      <h3 id="sim-feedback-title" class="font-display font-bold text-lg text-charbon"></h3>
      <p id="sim-feedback-text" class="text-sm text-muted mt-2"></p>
    </div>
  </div>
</section>

<script define:vars={{
  dates: t.simulator.dates,
  nominal: operation.nominalValue,
  maxAmount: operation.amount,
  minAmount: operation.minAmount,
  grossRate: operation.interestRate,
  locale,
  currencyPrefix: lang === 'en',
  warnMin: t.simulator.amountWarningMin,
  warnMax: t.simulator.amountWarningMax,
  warnStep: t.simulator.amountWarningStep,
  web3FormsAccessKey,
  ctaSubject: t.simulator.ctaEmailSubject,
  ctaBodyTemplate: t.simulator.ctaEmailBody,
  residenceLabels: { cemac: t.simulator.residenceCemac, 'hors-cemac': t.simulator.residenceHorsCemac },
  modalAmountInvalid: t.simulator.modalAmountInvalid,
  modalSuccessTitle: t.simulator.modalSuccessTitle,
  modalSuccessText: t.simulator.modalSuccessText,
  modalErrorTitle: t.simulator.modalErrorTitle,
  modalErrorText: t.simulator.modalErrorText,
}}>
  window.__simConfig = {
    dates, nominal, maxAmount, minAmount, grossRate, locale, currencyPrefix,
    warnMin, warnMax, warnStep, web3FormsAccessKey, ctaSubject, ctaBodyTemplate, residenceLabels,
    modalAmountInvalid, modalSuccessTitle, modalSuccessText, modalErrorTitle, modalErrorText,
  };
</script>
<script>
  import { initSimulator } from '../scripts/simulator';
  initSimulator();
</script>
