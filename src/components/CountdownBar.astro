---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import { operation } from '../data/operation';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<div class="sticky top-20 z-40 bg-[#0E2418] text-white" data-countdown-bar data-target={operation.subscriptionEndISO}>
  <div class="max-w-6xl mx-auto px-6 py-3 flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-4">
      <span class="text-[11px] uppercase tracking-wide text-white/60 hidden sm:inline">{t.countdown.label}</span>
      <div class="flex items-center gap-3 tabular">
        <div class="text-center">
          <div class="text-xl font-bold leading-none text-jaune-taux" data-cd="days">—</div>
          <div class="text-[10px] uppercase tracking-wide text-white/50">{t.countdown.days}</div>
        </div>
        <span class="text-white/20">:</span>
        <div class="text-center">
          <div class="text-xl font-bold leading-none text-jaune-taux" data-cd="hours">—</div>
          <div class="text-[10px] uppercase tracking-wide text-white/50">{t.countdown.hours}</div>
        </div>
        <span class="text-white/20">:</span>
        <div class="text-center">
          <div class="text-xl font-bold leading-none text-jaune-taux" data-cd="minutes">—</div>
          <div class="text-[10px] uppercase tracking-wide text-white/50">{t.countdown.minutes}</div>
        </div>
        <span class="text-white/20">:</span>
        <div class="text-center">
          <div class="text-xl font-bold leading-none text-jaune-taux" data-cd="seconds">—</div>
          <div class="text-[10px] uppercase tracking-wide text-white/50">{t.countdown.seconds}</div>
        </div>
      </div>
    </div>
    <div class="flex items-center gap-2 text-xs font-semibold bg-vert-marque/20 text-vert-vif rounded-full px-3 py-1.5" data-cd-status>
      <span class="w-1.5 h-1.5 rounded-full bg-vert-vif"></span>
      <span data-cd-status-text>{t.countdown.statusOpen}</span>
    </div>
  </div>
</div>

<script define:vars={{ closedLabel: t.countdown.statusClosed }}>
  window.__countdownClosedLabel = closedLabel;
</script>
<script>
  import { initCountdown } from '../scripts/countdown';
  initCountdown((window as any).__countdownClosedLabel);
</script>
