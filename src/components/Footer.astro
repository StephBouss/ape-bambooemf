---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import { siteMeta } from '../data/operation';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<footer class="bg-vert-foret text-white/80 py-12">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center gap-2 font-display font-bold text-white text-lg mb-6">
      <span class="w-8 h-8 rounded-lg bg-white/15 flex items-center justify-center text-sm">B</span>
      Bamboo Microfinance
    </div>

    <p class="text-xs text-white/70 max-w-3xl leading-relaxed mb-8 text-justify">{t.footer.legalNotice}</p>

    <div class="flex flex-col md:flex-row md:items-center justify-between gap-3 border-t border-white/15 pt-6 text-xs">
      <span>{t.footer.line1}</span>
      <span>{t.footer.line2}</span>
    </div>
    <div class="flex flex-col md:flex-row md:items-center justify-between gap-2 mt-3 text-[11px] text-white/60">
      <span>{t.footer.activePeriod}</span>
      <span>{siteMeta.domain}</span>
    </div>
  </div>
</footer>
