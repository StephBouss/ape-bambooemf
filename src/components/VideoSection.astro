---
import type { Lang } from '../i18n/utils';
import { useTranslations } from '../i18n/utils';
import { promoVideo } from '../data/operation';

interface Props { lang: Lang }
const { lang } = Astro.props;
const t = useTranslations(lang);
---
<section id="video" class="py-24 bg-white border-y border-filet">
  <div class="max-w-6xl mx-auto px-6">
    <div class="max-w-2xl mb-10 reveal-group">
      <div class="eyebrow reveal-item mb-3">{t.video.eyebrow}</div>
      <h2 class="reveal-item font-display font-bold text-3xl md:text-4xl text-charbon">{t.video.title}</h2>
      <p class="reveal-item text-muted mt-3">{t.video.lead}</p>
    </div>

    <div class="reveal-item rounded-card overflow-hidden border border-filet shadow-soft bg-charbon">
      <video id="promo-video" controls playsinline preload="metadata" class="w-full h-auto block">
        <source src={promoVideo.src} type="video/mp4" />
        {t.video.unsupported}
      </video>
    </div>
  </div>
</section>

<script>
  const video = document.getElementById('promo-video') as HTMLVideoElement | null;
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (video && !prefersReducedMotion) {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            video.play().catch(() => {
              // Autoplay avec son refusé par le navigateur (politique standard sans
              // interaction préalable de l'utilisateur avec le site) : on retente en
              // muet pour que la vidéo démarre quand même visuellement.
              video.muted = true;
              video.play().catch(() => {});
            });
            observer.disconnect();
          }
        }
      },
      { threshold: 0.5 },
    );
    observer.observe(video);
  }
</script>
